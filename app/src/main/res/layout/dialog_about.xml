<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background">

    <!-- Логотип -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/img_logo"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Название -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ПС 500кВ «Кустовая»"
        android:textColor="#1E293B"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Автоматизированная система осмотра оборудования"
        android:textColor="#64748B"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_marginBottom="16dp" />

    <!-- Информация -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Версия 1.0"
        android:textColor="#1E293B"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvCopyright"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="© 2026 Плотников Алексей Петрович"
        android:textColor="#1E293B"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvAuthor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Разработчик: Плотников А.П.\nДИП ПС 500кВ Кустовая"
        android:textColor="#64748B"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvLicense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Все права защищены."
        android:textColor="#FF5252"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Программа предназначена исключительно для использования\nна ПС 500кВ «Кустовая».\n\nКоммерческое использование и тиражирование\nтолько с письменного разрешения автора.\n\nНесанкционированное копирование,\nраспространение и модификация запрещены."
        android:textColor="#64748B"
        android:textSize="12sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="16dp" />

    <!-- Кнопка закрытия -->
    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="OK"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_green_rounded"
        android:textAllCaps="false" />

</LinearLayout>