<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background_warning">

    <!-- Иконка -->
    <TextView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:text="⚠️"
        android:textSize="48sp"
        android:gravity="center"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Заголовок -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Новый осмотр"
        android:textColor="#1E293B"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Описание -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Все несохранённые данные будут безвозвратно удалены.\n\nПродолжить?"
        android:textColor="#0F172A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:lineSpacingExtra="4dp" />

    <!-- Кнопка ДА -->
    <Button
        android:id="@+id/btnConfirmYes"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="✅ Да, начать новый"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_red_rounded"
        android:layout_marginBottom="12dp"
        android:textAllCaps="false" />

    <!-- Кнопка НЕТ -->
    <Button
        android:id="@+id/btnConfirmNo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="↩ Нет, вернуться"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_dark_rounded"
        android:textAllCaps="false" />

</LinearLayout>