<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 Графики показаний"
        android:textSize="18sp"
        android:textColor="#1565C0"
        android:layout_marginBottom="8dp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Маршрутная карта:"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginTop="4dp" />

    <Spinner
        android:id="@+id/spinnerSection"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Оборудование:"
        android:textSize="12sp"
        android:textColor="#757575" />

    <Spinner
        android:id="@+id/spinnerEquipment"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Параметр:"
        android:textSize="12sp"
        android:textColor="#757575" />

    <Spinner
        android:id="@+id/spinnerParameter"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnShowGraph"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="📊 Показать график"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1565C0"
        android:layout_marginBottom="12dp" />

    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:gravity="center"
        android:text="Выберите параметр для отображения графика"
        android:textSize="16sp"
        android:textColor="#757575"
        android:visibility="gone" />

</LinearLayout>