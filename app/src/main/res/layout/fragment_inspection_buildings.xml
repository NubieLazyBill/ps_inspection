<!-- Компрессорная №1 -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:elevation="2dp"
    android:padding="16dp"
    android:layout_marginTop="8dp">

    <!-- Заголовок с кнопками -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E3F2FD"
        android:padding="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Компрессорная №1"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnMediaCompressor1"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp" />

        <ImageButton
            android:id="@+id/btnCommentCompressor1"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_comment"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp" />
    </LinearLayout>

    <!-- Тело карточки -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Запорная арматура -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Арматура"
                android:textSize="12sp"
                android:textColor="#666" />

            <ImageButton
                android:id="@+id/btnCompressor1Valve"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_valve"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Обогрев -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Обогрев"
                android:textSize="12sp"
                android:textColor="#666" />

            <ImageButton
                android:id="@+id/btnCompressor1Heating"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_heating"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Температура -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Температура, °C"
                android:textSize="12sp"
                android:textColor="#666" />

            <EditText
                android:id="@+id/etCompressor1Temp"
                android:layout_width="80dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:hint="0"
                android:inputType="numberSigned|numberDecimal"
                android:background="@drawable/edittext_border"
                android:padding="8dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>