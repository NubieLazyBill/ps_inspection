<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainMenuFragment">

    <!-- ⭐ ГЛАВНОЕ МЕНЮ -->
    <fragment
        android:id="@+id/mainMenuFragment"
        android:name="com.example.ps_inspection.ui.fragments.MainMenuFragment"
        android:label="Главное меню"
        tools:layout="@layout/fragment_main_menu">

        <action
            android:id="@+id/action_mainMenu_to_homeScreen"
            app:destination="@id/homeScreen" />

        <action
            android:id="@+id/action_mainMenu_to_archiveFragment"
            app:destination="@id/archiveFragment" />
    </fragment>

    <!-- ЭКРАН ВЫБОРА ОБЪЕКТОВ -->
    <fragment
        android:id="@+id/homeScreen"
        android:name="com.example.ps_inspection.ui.fragments.HomeScreen"
        android:label="Выбор объекта"
        tools:layout="@layout/fragment_home_screen">

        <action
            android:id="@+id/action_homeScreen_to_inspectionORU35"
            app:destination="@id/inspectionORU35" />

        <action
            android:id="@+id/action_homeScreen_to_inspectionORU2202"
            app:destination="@id/inspectionORU220" />

        <action
            android:id="@+id/action_homeScreen_to_inspectionORU500"
            app:destination="@id/inspectionORU500" />

        <action
            android:id="@+id/action_homeScreen_to_inspectionATG"
            app:destination="@id/inspectionATG" />

        <action
            android:id="@+id/action_homeScreen_to_inspectionBuildings"
            app:destination="@id/inspectionBuildings" />

        <action
            android:id="@+id/action_homeScreen_to_archiveFragment"
            app:destination="@id/archiveFragment" />
    </fragment>

    <!-- ФРАГМЕНТЫ ОСМОТРА -->
    <fragment
        android:id="@+id/inspectionORU35"
        android:name="com.example.ps_inspection.ui.fragments.inspections.InspectionORU35"
        android:label="Осмотр ОРУ-35" />

    <fragment
        android:id="@+id/inspectionORU220"
        android:name="com.example.ps_inspection.ui.fragments.inspections.InspectionORU220"
        android:label="Осмотр ОРУ-220" />

    <fragment
        android:id="@+id/inspectionORU500"
        android:name="com.example.ps_inspection.ui.fragments.inspections.InspectionORU500"
        android:label="Осмотр ОРУ-500" />

    <fragment
        android:id="@+id/inspectionATG"
        android:name="com.example.ps_inspection.ui.fragments.inspections.InspectionATG"
        android:label="Осмотр АТГ" />

    <fragment
        android:id="@+id/inspectionBuildings"
        android:name="com.example.ps_inspection.ui.fragments.inspections.InspectionBuildings"
        android:label="Осмотр зданий" />

    <!-- АРХИВ -->
    <fragment
        android:id="@+id/archiveFragment"
        android:name="com.example.ps_inspection.ui.fragments.ArchiveFragment"
        android:label="Архив осмотров" />

</navigation>