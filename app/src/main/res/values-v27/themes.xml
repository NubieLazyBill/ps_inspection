<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Ps_inspection" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color - тёмный, чтобы текст был белым -->
        <item name="android:statusBarColor">#1E293B</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Отступ под системные элементы -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>